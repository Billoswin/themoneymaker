# Copy to .env (do not commit .env)
#
# Local dev:
# - Start Postgres with: docker compose up -d db
# - Run: npm run db:deploy
# - Run: npm run dev
DATABASE_URL="postgresql://app:app@localhost:5432/app"

# Required (we'll use this for sessions + token encryption)
APP_SECRET="change-me-to-a-long-random-string"

# If you access the app via VM IP/hostname, set this so redirects never use 0.0.0.0/localhost.
PUBLIC_BASE_URL="http://localhost:3000"

# EVE SSO (set in CCP dev portal)
EVE_SSO_CLIENT_ID=""
EVE_SSO_CLIENT_SECRET=""
EVE_SSO_REDIRECT_URI="http://localhost:3000/api/auth/eve/callback"
EVE_SSO_SCOPES="esi-wallet.read_corporation_wallets.v1 esi-assets.read_corporation_assets.v1 esi-corporations.read_structures.v1"

# zKillboard
ZKILL_BASE_URL="https://zkillboard.com"
ZKILL_USER_AGENT="the-money-maker (your-email@example.com)"
GSF_ALLIANCE_ID=""

# ESI
ESI_BASE_URL="https://esi.evetech.net/latest"

